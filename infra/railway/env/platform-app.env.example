# Railway service: platform-app -> Variables -> Raw Editor
# Copy this whole file into the platform-app service variables.
# Adjust Postgres/Redis service names if your Railway services are not named
# exactly "Postgres" and "Redis".

DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}
COOKIE_SECRET=replace-with-openssl-rand-base64-32

PLATFORM_HOST_APP=${{shared.PLATFORM_HOST_APP}}
PLATFORM_HOST_API=${{shared.PLATFORM_HOST_API}}

ANTHROPIC_API_KEY=${{shared.ANTHROPIC_API_KEY}}
ANTHROPIC_BASE_URL=${{shared.ANTHROPIC_BASE_URL}}
MODEL_PARSE=${{shared.MODEL_PARSE}}
MODEL_QA=${{shared.MODEL_QA}}
MODEL_VISION=${{shared.MODEL_VISION}}

ASSISTANT_BASE_URL=${{shared.ASSISTANT_BASE_URL}}
ASSISTANT_MODEL=${{shared.ASSISTANT_MODEL}}
ASSISTANT_EFFORT=${{shared.ASSISTANT_EFFORT}}
ASSISTANT_MAX_TOOL_ITERATIONS=${{shared.ASSISTANT_MAX_TOOL_ITERATIONS}}

OCR_PROVIDER=${{shared.OCR_PROVIDER}}
EXTRACTOR_PROVIDER=${{shared.EXTRACTOR_PROVIDER}}

MISTRAL_API_KEY=${{shared.MISTRAL_API_KEY}}
MISTRAL_BASE_URL=${{shared.MISTRAL_BASE_URL}}
MISTRAL_OCR_MODEL=${{shared.MISTRAL_OCR_MODEL}}
MISTRAL_OCR_TIMEOUT_SECONDS=${{shared.MISTRAL_OCR_TIMEOUT_SECONDS}}

MINERU_API_TOKEN=${{shared.MINERU_API_TOKEN}}
MINERU_BASE_URL=${{shared.MINERU_BASE_URL}}
MINERU_MODEL_VERSION=${{shared.MINERU_MODEL_VERSION}}
MINERU_LANGUAGE=${{shared.MINERU_LANGUAGE}}
MINERU_ENABLE_TABLE=${{shared.MINERU_ENABLE_TABLE}}
MINERU_ENABLE_FORMULA=${{shared.MINERU_ENABLE_FORMULA}}
MINERU_IS_OCR=${{shared.MINERU_IS_OCR}}
MINERU_POLL_INTERVAL_SECONDS=${{shared.MINERU_POLL_INTERVAL_SECONDS}}
MINERU_TIMEOUT_SECONDS=${{shared.MINERU_TIMEOUT_SECONDS}}

VISION_AGENT_API_KEY=${{shared.VISION_AGENT_API_KEY}}
LANDINGAI_ENVIRONMENT=${{shared.LANDINGAI_ENVIRONMENT}}
LANDINGAI_PARSE_MODEL=${{shared.LANDINGAI_PARSE_MODEL}}
LANDINGAI_EXTRACT_MODEL=${{shared.LANDINGAI_EXTRACT_MODEL}}
LANDINGAI_CLASSIFY_MODEL=${{shared.LANDINGAI_CLASSIFY_MODEL}}
LANDINGAI_SPLIT_MODEL=${{shared.LANDINGAI_SPLIT_MODEL}}
LANDINGAI_LARGE_FILE_PAGES_THRESHOLD=${{shared.LANDINGAI_LARGE_FILE_PAGES_THRESHOLD}}

STORAGE_BACKEND=${{shared.STORAGE_BACKEND}}
S3_BUCKET=${{shared.S3_BUCKET}}
S3_ENDPOINT_URL=${{shared.S3_ENDPOINT_URL}}
S3_REGION=${{shared.S3_REGION}}
S3_ACCESS_KEY_ID=${{shared.S3_ACCESS_KEY_ID}}
S3_SECRET_ACCESS_KEY=${{shared.S3_SECRET_ACCESS_KEY}}

LOG_LEVEL=${{shared.LOG_LEVEL}}
