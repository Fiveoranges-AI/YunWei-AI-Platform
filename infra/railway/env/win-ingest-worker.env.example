# Railway service: win-ingest-worker -> Variables -> Raw Editor
# Copy this whole file into the win-ingest-worker service variables.
# Adjust Postgres/Redis service names if your Railway services are not named
# exactly "Postgres" and "Redis".

# ---------------------------------------------------------------------------
# Required worker runtime
# ---------------------------------------------------------------------------
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# ---------------------------------------------------------------------------
# DeepSeek-compatible LLM upstream.
# Keep these values identical to platform-app.
# Variable names are historical because the app uses Anthropic's SDK shape.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=replace-with-deepseek-api-key
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
MODEL_PARSE=deepseek-v4-flash
MODEL_QA=deepseek-v4-flash
MODEL_VISION=deepseek-v4-flash

# ---------------------------------------------------------------------------
# Win ingest provider selection.
# Keep these values identical to platform-app while /api/win/ingest/auto
# exists on the web service.
# OCR_PROVIDER:       mistral | mineru
# EXTRACTOR_PROVIDER: landingai | deepseek
# ---------------------------------------------------------------------------
OCR_PROVIDER=mistral
EXTRACTOR_PROVIDER=landingai

# ---------------------------------------------------------------------------
# OCR provider: Mistral.
# Required when OCR_PROVIDER=mistral.
# ---------------------------------------------------------------------------
MISTRAL_API_KEY=replace-me
MISTRAL_BASE_URL=https://api.mistral.ai
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_OCR_TIMEOUT_SECONDS=120

# ---------------------------------------------------------------------------
# OCR provider: MinerU.
# Required only when OCR_PROVIDER=mineru.
# ---------------------------------------------------------------------------
MINERU_API_TOKEN=
MINERU_BASE_URL=https://mineru.net
MINERU_MODEL_VERSION=vlm
MINERU_LANGUAGE=ch
MINERU_ENABLE_TABLE=true
MINERU_ENABLE_FORMULA=true
MINERU_IS_OCR=true
MINERU_POLL_INTERVAL_SECONDS=2
MINERU_TIMEOUT_SECONDS=180

# ---------------------------------------------------------------------------
# Extractor provider: LandingAI.
# Required when EXTRACTOR_PROVIDER=landingai.
# ---------------------------------------------------------------------------
VISION_AGENT_API_KEY=replace-me
LANDINGAI_ENVIRONMENT=production
LANDINGAI_PARSE_MODEL=dpt-2-latest
LANDINGAI_EXTRACT_MODEL=extract-latest
LANDINGAI_CLASSIFY_MODEL=classify-latest
LANDINGAI_SPLIT_MODEL=split-latest
LANDINGAI_LARGE_FILE_PAGES_THRESHOLD=50

# ---------------------------------------------------------------------------
# Shared object storage for async ingest jobs.
# Keep these values identical to platform-app.
# ---------------------------------------------------------------------------
STORAGE_BACKEND=s3
S3_BUCKET=replace-me
S3_ENDPOINT_URL=https://replace-me.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me

# ---------------------------------------------------------------------------
# Worker runtime
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
WORKER_MAX_JOBS=100
