{
  "type": "object",
  "properties": {
    "customer": {
      "type": "object",
      "description": "Customer / buyer / Party A side of the invoice or payment.",
      "properties": {
        "full_name": {"type": "string", "description": "Full legal name of the customer."},
        "short_name": {"type": "string", "description": "Short name."},
        "tax_id": {"type": "string", "description": "Tax ID."},
        "address": {"type": "string", "description": "Address."}
      }
    },
    "invoice": {
      "type": "object",
      "description": "Invoice header fields.",
      "properties": {
        "invoice_number": {"type": "string", "description": "Invoice number.", "x-alternativeNames": ["发票号码"]},
        "invoice_code": {"type": "string", "description": "Invoice code.", "x-alternativeNames": ["发票代码"]},
        "invoice_type": {"type": "string", "description": "Invoice type (special / general / electronic).", "enum": ["vat_special", "vat_general", "electronic", "other"]},
        "issue_date": {"type": "string", "description": "Issue date YYYY-MM-DD.", "format": "date"},
        "amount_without_tax": {"type": "string", "description": "Amount before tax."},
        "tax_amount": {"type": "string", "description": "Tax amount."},
        "amount_total": {"type": "string", "description": "Total amount including tax."},
        "currency": {"type": "string", "description": "Currency code."},
        "seller_name": {"type": "string", "description": "Seller name on the invoice."},
        "buyer_name": {"type": "string", "description": "Buyer name on the invoice."},
        "status": {"type": "string", "description": "Invoice status if printed (paid / pending / cancelled / red).", "enum": ["paid", "pending", "cancelled", "red", "other"]}
      }
    },
    "items": {
      "type": "array",
      "description": "Invoice line items.",
      "items": {
        "type": "object",
        "properties": {
          "description": {"type": "string", "description": "Line description."},
          "specification": {"type": "string", "description": "Spec/model."},
          "quantity": {"type": "string", "description": "Quantity."},
          "unit": {"type": "string", "description": "Unit of measure."},
          "unit_price": {"type": "string", "description": "Unit price."},
          "amount": {"type": "string", "description": "Line amount."}
        }
      }
    },
    "payment": {
      "type": "object",
      "description": "Payment record fields.",
      "properties": {
        "payment_date": {"type": "string", "description": "Payment date YYYY-MM-DD.", "format": "date"},
        "amount": {"type": "string", "description": "Payment amount."},
        "payer_name": {"type": "string", "description": "Payer name."},
        "payee_name": {"type": "string", "description": "Payee name."},
        "bank_name": {"type": "string", "description": "Bank name."},
        "bank_account": {"type": "string", "description": "Bank account number."},
        "transaction_id": {"type": "string", "description": "Transaction reference."},
        "method": {"type": "string", "description": "Payment method.", "enum": ["transfer", "cash", "check", "card", "online", "other"]}
      }
    },
    "reconciliation": {
      "type": "object",
      "description": "Reconciliation statement fields.",
      "properties": {
        "period_start": {"type": "string", "description": "Period start date YYYY-MM-DD.", "format": "date"},
        "period_end": {"type": "string", "description": "Period end date YYYY-MM-DD.", "format": "date"},
        "opening_balance": {"type": "string", "description": "Opening balance."},
        "closing_balance": {"type": "string", "description": "Closing balance."},
        "current_period_amount": {"type": "string", "description": "Current period total."},
        "unpaid_amount": {"type": "string", "description": "Unpaid amount."}
      }
    },
    "extraction_warnings": {"type": "array", "description": "Warnings.", "items": {"type": "string", "description": "One warning."}}
  }
}
