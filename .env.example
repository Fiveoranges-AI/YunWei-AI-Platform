# Platform-level secrets only — does not grow with the number of agents.
# Per-agent secrets live in agents/<client>-<agent>/.env (see agents/README.md).

# Cloudflare Tunnel
TUNNEL_TOKEN=eyJ...replace-me

# Platform
PLATFORM_PORT=8080
PLATFORM_DB_PATH=/data/platform.db
PROXY_LOG_DB_PATH=/data/proxy_log.db
PLATFORM_HOST_APP=app.fiveoranges.ai
PLATFORM_HOST_API=api.fiveoranges.ai
COOKIE_SECRET=replace-with-32-bytes-base64

# Data center sidebar assistant (docs/data-layer.md §3.3). Optional —
# absent / empty disables the assistant chat; the rest of /data still works.
ANTHROPIC_API_KEY=sk-ant-...replace-me
# ASSISTANT_MODEL=claude-sonnet-4-6   # default

ADMIN_BOOTSTRAP_USER=xuzong
ADMIN_BOOTSTRAP_PASSWORD=replace-after-first-login
