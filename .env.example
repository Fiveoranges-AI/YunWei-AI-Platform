# Platform-level secrets only — does not grow with the number of agents.
# Per-agent secrets live in agents/<client>-<agent>/.env (see agents/README.md).

# Cloudflare Tunnel
TUNNEL_TOKEN=eyJ...replace-me

# Platform
PLATFORM_PORT=8080
PLATFORM_DB_PATH=/data/platform.db
PROXY_LOG_DB_PATH=/data/proxy_log.db
PLATFORM_HOST_APP=app.fiveoranges.ai
PLATFORM_HOST_API=api.fiveoranges.ai
COOKIE_SECRET=replace-with-32-bytes-base64

# Data center sidebar assistant (docs/data-layer.md §3.3). Optional —
# absent / empty disables the assistant chat; the rest of /data still works.
#
# Default provider is DeepSeek via its Anthropic-compatible endpoint:
#   ASSISTANT_BASE_URL=https://api.deepseek.com/anthropic
#   ASSISTANT_MODEL=deepseek-v4-flash    # or deepseek-v4-pro
#   DEEPSEEK_API_KEY=sk-...
# Switching back to Claude proper:
#   ASSISTANT_BASE_URL=https://api.anthropic.com
#   ASSISTANT_MODEL=claude-opus-4-7
#   ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...replace-me
# ASSISTANT_BASE_URL=https://api.deepseek.com/anthropic
# ASSISTANT_MODEL=deepseek-v4-flash
# ASSISTANT_EFFORT=medium

# 智通客户 OCR (PDF 扫描件 / 名片照片 / 微信截图)
MISTRAL_API_KEY=replace-me
# MISTRAL_OCR_MODEL=mistral-ocr-latest
# MISTRAL_BASE_URL=https://api.mistral.ai

ADMIN_BOOTSTRAP_USER=xuzong
ADMIN_BOOTSTRAP_PASSWORD=replace-after-first-login
