# Platform-level secrets and configuration.
# Copy to `.env` at repo root and fill in real values for the keys you need.
# `.env` is git-ignored.

# ---------------------------------------------------------------------------
# REQUIRED — platform-api will refuse to start without these
# ---------------------------------------------------------------------------

# Postgres connection (sync driver — psycopg). Platform metadata DB.
DATABASE_URL=postgresql://platform:platform@localhost:5432/platform

# Redis — used for sessions, CSRF tokens, and the RQ ingest queue.
REDIS_URL=redis://localhost:6379/0

# 32-byte base64 key for app_session cookie signing. Generate with:
#   openssl rand -base64 32
COOKIE_SECRET=replace-with-32-bytes-base64

# ---------------------------------------------------------------------------
# Cloudflare Tunnel (only needed for the infra/local/ compose stack)
# ---------------------------------------------------------------------------

TUNNEL_TOKEN=eyJ...replace-me

# ---------------------------------------------------------------------------
# Hostnames (optional; defaults are app.fiveoranges.ai / api.fiveoranges.ai)
# ---------------------------------------------------------------------------

# PLATFORM_HOST_APP=app.fiveoranges.ai
# PLATFORM_HOST_API=api.fiveoranges.ai

# ---------------------------------------------------------------------------
# Admin bootstrap — consumed by scripts/bootstrap-dev.sh
# ---------------------------------------------------------------------------

ADMIN_BOOTSTRAP_USER=xuzong
ADMIN_BOOTSTRAP_PASSWORD=replace-after-first-login
# BOOTSTRAP_ENTERPRISE_ID=yinhu
# BOOTSTRAP_ENTERPRISE_NAME=银湖石墨

# ---------------------------------------------------------------------------
# LLM upstream for the /api/me + /admin sidebar assistant
# (docs/data-layer.md §3.3 — optional; absent disables the assistant chat)
#
# Default: DeepSeek via its Anthropic-compatible endpoint.
#   ASSISTANT_BASE_URL=https://api.deepseek.com/anthropic
#   ASSISTANT_MODEL=deepseek-v4-flash    # or deepseek-v4-pro
#   DEEPSEEK_API_KEY=sk-...
# Switching to Claude proper:
#   ASSISTANT_BASE_URL=https://api.anthropic.com
#   ASSISTANT_MODEL=claude-opus-4-7
#   ANTHROPIC_API_KEY=sk-ant-...
# ---------------------------------------------------------------------------

DEEPSEEK_API_KEY=sk-...replace-me
# ANTHROPIC_API_KEY=sk-ant-...
# ASSISTANT_BASE_URL=https://api.deepseek.com/anthropic
# ASSISTANT_MODEL=deepseek-v4-flash
# ASSISTANT_EFFORT=medium
# ASSISTANT_MAX_TOOL_ITERATIONS=8

# ---------------------------------------------------------------------------
# Win ingest pipeline — OCR + extractor providers
# ---------------------------------------------------------------------------

# OCR provider for non-text inputs (scanned PDFs, images).
# OCR_PROVIDER=mistral        # default. Other option: mineru
MISTRAL_API_KEY=replace-me
# MISTRAL_OCR_MODEL=mistral-ocr-latest
# MISTRAL_BASE_URL=https://api.mistral.ai

# MinerU 精准解析 — only needed when OCR_PROVIDER=mineru
# MINERU_API_TOKEN=

# Extractor provider for schema-routed extraction.
# EXTRACTOR_PROVIDER=landingai    # default. Other option: deepseek

# LandingAI ADE (when EXTRACTOR_PROVIDER=landingai). Mistral remains the OCR
# parser regardless.
VISION_AGENT_API_KEY=replace-me
# LANDINGAI_ENVIRONMENT=production         # or "eu" (not "us")
# LANDINGAI_PARSE_MODEL=dpt-2-latest
# LANDINGAI_EXTRACT_MODEL=extract-latest
# LANDINGAI_CLASSIFY_MODEL=classify-latest
# LANDINGAI_SPLIT_MODEL=split-latest

# ---------------------------------------------------------------------------
# Storage — local volume or S3-compatible
# ---------------------------------------------------------------------------

# STORAGE_BACKEND=local                 # default. Other option: s3
# S3_BUCKET=
# S3_ENDPOINT_URL=                      # for Cloudflare R2 / MinIO
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Optional — worker / observability
# ---------------------------------------------------------------------------

# LOG_LEVEL=INFO
# WORKER_MAX_JOBS=
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
