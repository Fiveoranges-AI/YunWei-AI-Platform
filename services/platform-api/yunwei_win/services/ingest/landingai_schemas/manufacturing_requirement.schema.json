{
  "type": "object",
  "properties": {
    "customer": {
      "type": "object",
      "description": "Customer / buyer side.",
      "properties": {
        "full_name": {"type": "string", "description": "Customer full name."},
        "short_name": {"type": "string", "description": "Short name."},
        "tax_id": {"type": "string", "description": "Tax ID."},
        "address": {"type": "string", "description": "Address."}
      }
    },
    "product": {
      "type": "object",
      "description": "Product identity.",
      "properties": {
        "product_name": {"type": "string", "description": "Product name."},
        "product_code": {"type": "string", "description": "Internal/external product code."},
        "category": {"type": "string", "description": "Product category."}
      }
    },
    "spec": {
      "type": "object",
      "description": "Technical specification fields.",
      "properties": {
        "specification": {"type": "string", "description": "Spec text."},
        "material": {"type": "string", "description": "Material."},
        "grade": {"type": "string", "description": "Grade."},
        "technical_parameters": {"type": "string", "description": "Technical parameters block."},
        "quality_standard": {"type": "string", "description": "Quality standard / accept criteria."},
        "packaging_requirement": {"type": "string", "description": "Packaging requirement."},
        "inspection_requirement": {"type": "string", "description": "Inspection requirement."}
      }
    },
    "customer_requirement": {
      "type": "object",
      "description": "Customer-side manufacturing requirements / preferences.",
      "properties": {
        "requirement_type": {"type": "string", "description": "Requirement type.", "enum": ["spec", "delivery", "quality", "packaging", "documentation", "other"]},
        "description": {"type": "string", "description": "Detailed description."},
        "priority": {"type": "string", "description": "Priority.", "enum": ["urgent", "high", "normal", "low"]},
        "effective_date": {"type": "string", "description": "Effective date YYYY-MM-DD.", "format": "date"},
        "raw_text": {"type": "string", "description": "Verbatim excerpt."}
      }
    },
    "safety_stock_rule": {
      "type": "object",
      "description": "Safety stock / replenishment rule extracted for this product.",
      "properties": {
        "minimum_quantity": {"type": "string", "description": "Minimum stock level."},
        "target_quantity": {"type": "string", "description": "Target stock level."},
        "unit": {"type": "string", "description": "Unit."},
        "lead_time_days": {"type": "string", "description": "Lead time in days."},
        "monthly_usage": {"type": "string", "description": "Monthly usage."},
        "moq": {"type": "string", "description": "Minimum order quantity."},
        "replenishment_trigger": {"type": "string", "description": "When to trigger replenishment."}
      }
    },
    "extraction_warnings": {"type": "array", "description": "Warnings.", "items": {"type": "string", "description": "One warning."}}
  }
}
