{
  "type": "object",
  "properties": {
    "customer": {
      "type": "object",
      "description": "Customer mentioned in the conversation / note.",
      "properties": {
        "full_name": {"type": "string", "description": "Customer full name."},
        "short_name": {"type": "string", "description": "Short name."},
        "tax_id": {"type": "string", "description": "Tax ID."},
        "address": {"type": "string", "description": "Address."}
      }
    },
    "summary": {"type": "string", "description": "1-2 sentence Chinese summary of the conversation/note."},
    "events": {
      "type": "array",
      "description": "Significant customer interactions already happened.",
      "items": {
        "type": "object",
        "properties": {
          "title": {"type": "string", "description": "Short event title."},
          "event_type": {"type": "string", "description": "Event type.", "enum": ["contract_signed", "order_placed", "payment_received", "payment_due", "shipment", "delivery", "acceptance", "quality_issue", "complaint", "meeting", "call", "message", "introduction", "dispute", "other"]},
          "occurred_at": {"type": "string", "description": "Occurred datetime ISO 8601 or Chinese date if possible."},
          "description": {"type": "string", "description": "Event detail."},
          "raw_excerpt": {"type": "string", "description": "Verbatim excerpt."},
          "confidence": {"type": "string", "description": "Self-rated 0-1 confidence."}
        }
      }
    },
    "commitments": {
      "type": "array",
      "description": "Promises / commitments mentioned (who → whom → by when).",
      "items": {
        "type": "object",
        "properties": {
          "summary": {"type": "string", "description": "One-line summary."},
          "description": {"type": "string", "description": "Detail."},
          "direction": {"type": "string", "description": "Commitment direction.", "enum": ["we_to_customer", "customer_to_us", "mutual"]},
          "due_date": {"type": "string", "description": "Due date YYYY-MM-DD.", "format": "date"},
          "raw_excerpt": {"type": "string", "description": "Verbatim excerpt."},
          "confidence": {"type": "string", "description": "0-1 confidence."}
        }
      }
    },
    "tasks": {
      "type": "array",
      "description": "Action items for our team.",
      "items": {
        "type": "object",
        "properties": {
          "title": {"type": "string", "description": "Task title."},
          "description": {"type": "string", "description": "Detail."},
          "assignee": {"type": "string", "description": "Assignee if mentioned."},
          "due_date": {"type": "string", "description": "Due date YYYY-MM-DD.", "format": "date"},
          "priority": {"type": "string", "description": "Priority.", "enum": ["urgent", "high", "normal", "low"]},
          "raw_excerpt": {"type": "string", "description": "Verbatim excerpt."}
        }
      }
    },
    "risk_signals": {
      "type": "array",
      "description": "Red flags about the customer relationship / payment / quality.",
      "items": {
        "type": "object",
        "properties": {
          "summary": {"type": "string", "description": "One-line risk summary."},
          "description": {"type": "string", "description": "Detail."},
          "severity": {"type": "string", "description": "Severity.", "enum": ["low", "medium", "high"]},
          "kind": {"type": "string", "description": "Risk kind.", "enum": ["payment", "quality", "churn", "legal", "supply", "relationship", "other"]},
          "raw_excerpt": {"type": "string", "description": "Verbatim excerpt."},
          "confidence": {"type": "string", "description": "0-1 confidence."}
        }
      }
    },
    "memory_items": {
      "type": "array",
      "description": "Long-term facts / preferences / persona notes about the customer.",
      "items": {
        "type": "object",
        "properties": {
          "content": {"type": "string", "description": "One-sentence fact / preference."},
          "kind": {"type": "string", "description": "Memory kind.", "enum": ["preference", "persona", "context", "history", "decision_maker", "other"]},
          "raw_excerpt": {"type": "string", "description": "Verbatim excerpt."},
          "confidence": {"type": "string", "description": "0-1 confidence."}
        }
      }
    },
    "extraction_warnings": {"type": "array", "description": "Warnings.", "items": {"type": "string", "description": "One warning."}}
  }
}
