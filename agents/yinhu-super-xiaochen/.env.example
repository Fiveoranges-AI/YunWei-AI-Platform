# Per-agent secrets for yinhu/super-xiaochen.
#
# Generate this file by running:
#   bash ops/bootstrap.sh
# which calls `platform-admin add-tenant` and writes the resulting env
# block here. Manual rotation: `platform-admin rotate-tenant-key yinhu
# super-xiaochen` then update HMAC_SECRET_CURRENT/PREV here and restart
# the agent container.

# HMAC — DB is the source of truth (tenants.hmac_secret_*); these values
# must match the tenants row for this client_id/agent_id.
TENANT_CLIENT=yinhu
TENANT_AGENT=super-xiaochen
HMAC_SECRET_CURRENT=replace-with-32-bytes-base64
HMAC_KEY_ID_CURRENT=k-replace
HMAC_SECRET_PREV=
HMAC_KEY_ID_PREV=

# Anthropic / DeepSeek-compatible upstream
ANTHROPIC_API_KEY=replace-with-key
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
MODEL_PRO=deepseek-v4-pro
MODEL_FLASH=deepseek-v4-flash
AGENT_VERSION=yinhu-1.0.0
