# Keep the build context lean — exclude large dirs not needed by platform/Dockerfile.
# Stage 1 (node) copies app/package*.json + app/src; node_modules is rebuilt via npm ci.
# Stage 2 (python) copies platform/pyproject.toml + platform/platform_app + platform/migrations + platform/static.

**/node_modules/
**/dist/
.git/
.venv/
__pycache__/
*.pyc
.pytest_cache/
landing/
agents/
ops/
docs/
