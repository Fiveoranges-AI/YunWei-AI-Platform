# Keep the build context lean — exclude large dirs not needed by
# services/platform-api/Dockerfile.
# Stage 1 (node) copies apps/win-web/ package*.json + src; node_modules
# rebuilt via npm ci.
# Stage 2 (python) copies services/platform-api/pyproject.toml +
# platform_app + yunwei_win + migrations + static + prompts.

**/node_modules/
**/dist/
.git/
.venv/
__pycache__/
*.pyc
.pytest_cache/
apps/marketing-web/
agents/
scripts/
docs/
